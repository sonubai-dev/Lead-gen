{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A business lead identified from Google Maps",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "hasWebsite": { "type": "boolean" },
        "websiteUrl": { "type": "string" },
        "cityCountry": { "type": "string" },
        "conversationHistory": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { 
          "type": "string",
          "enum": ["new", "contacted", "engaged", "qualified", "closed-won", "closed-lost"]
        }
      },
      "required": ["businessName", "phoneNumber", "hasWebsite", "status", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Storage for potential business leads"
    }
  }
}
